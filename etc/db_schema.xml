<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/db_schema.xsd">
    
    <table name="sales_order_address">
        <index referenceId="SALES_ORDER_ADDRESS_TELEPHONE" indexType="btree">
            <column name="telephone"/>
        </index>
    </table>

    <table name="sales_order">
        <index referenceId="SALES_ORDER_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="SALES_ORDER_CUSTOMER_EMAIL" indexType="btree">
            <column name="customer_email"/>
        </index>
    </table>
</schema>
